# ─── V1 (required) ───────────────────────────────────────────
# Neon: the DIRECT (non-pooled) connection string is required for `prisma migrate`
# (DDL needs a persistent connection). Pooled URLs work for normal queries but break
# migrations. Use the direct URL everywhere unless you know you need pooling.
# Local Postgres: any valid connection string works.
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/timetracker?sslmode=require

# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
NODE_ENV=development

# Generate with: openssl rand -base64 32  (must decode to exactly 32 bytes)
TOKEN_ENCRYPTION_KEY=

# ─── V2 ClickUp (placeholders — not used in V1) ──────────────
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=
CLICKUP_REDIRECT_URI=http://localhost:3000/api/clickup/callback
CLICKUP_WEBHOOK_SECRET_KEY=
